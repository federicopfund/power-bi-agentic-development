	column IsWeekend
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 472d44c7-1028-4b7c-9bdf-03a1bae43f41
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsWeekend]

		annotation SummarizationSetBy = Automatic

	partition Dim_Date = calculated
		mode: import
		source = ```
				
				VAR MinDate =
				    MINX ( ALL ( Billing ), Billing[date] )
				VAR MaxDate =
				    MAXX ( ALL ( Billing ), Billing[date] )
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( MinDate, MaxDate ),
				    "DateKey", VALUE ( FORMAT ( [Date], "YYYYMMDD" ) ),
				    "Year", YEAR ( [Date] ),
				    "MonthNumber", MONTH ( [Date] ),
				    "MonthName",UPPER ( LEFT ( FORMAT ( [Date], "MMMM" ), 1 ) )
				    & LOWER ( MID ( FORMAT ( [Date], "MMMM" ), 2, 20 ) ),
				    "MonthShort", FORMAT ( [Date], "MMM" ),
				    "YearMonth", FORMAT ( [Date], "YYYY-MM" ),
				    "YearMonthSort", YEAR ( [Date] ) * 100 + MONTH ( [Date] ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "YearQuarter", FORMAT ( [Date], "YYYY" ) & "-Q" & FORMAT ( [Date], "Q" ),
				    "WeekOfYear", WEEKNUM ( [Date], 2 ),
				    "Day", DAY ( [Date] ),
				    "DayOfWeekNumber", WEEKDAY ( [Date], 2 ),
				    "DayOfWeekName", FORMAT ( [Date], "dddd" ),
				    "IsWeekend", IF ( WEEKDAY ( [Date], 2 ) >= 6, TRUE (), FALSE () )
				)
				
				```

	annotation PBI_Id = 76d0bcfa2fe0489c8b74808d0d88eeff

