	measure 'Premium Cost per Request' = ```
			
			DIVIDE ( [Premium Gross Amount], [Premium Requests], 0 )
			
			```
		formatString: \$#,0.000;(\$#,0.000);\$#,0.000
		lineageTag: c15adf76-3bfd-4266-a0d0-496bdea9f9e3

		annotation PBI_FormatHint = {"currencyCulture":"es-US"}

	measure 'Monthly Quota' = ```
			
			MAX ( Billing[total_monthly_quota] )
			
			```
		lineageTag: 635be5b3-680a-484d-b76c-94556241fb65

	measure 'Exceeded Premium Requests' = ```
			
			CALCULATE ( [Premium Requests], Billing[exceeds_quota] = TRUE () )
			
			```
		formatString: 0
		lineageTag: 246d8958-b601-43bd-92ac-765c19fe9230

	measure 'In-Quota Premium Requests' = ```
			
			[Premium Requests] - [Exceeded Premium Requests]
			
			```
		formatString: #,0.###############\ "€";-#,0.###############\ "€";#,0.###############\ "€"
		lineageTag: 6ad9a3b9-5cfb-49de-a472-553847f4ccce

