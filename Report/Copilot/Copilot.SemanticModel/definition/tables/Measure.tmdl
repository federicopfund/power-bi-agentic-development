table Measure
	lineageTag: d566c84e-4621-46b5-98a8-1241df489500

	measure 'Gross Amount Total' = ```
			
			/* Discount Total (ahorro por plan) */
			SUM ( Billing[gross_amount] )
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 4e0f3a29-932d-44b8-a839-3c8d5827c1a5

	measure 'Net Amount Total' = ```
			
			/* Net Amount Total (costo real) */
			SUM ( Billing[net_amount] )
			
			```
		formatString: 0
		lineageTag: a74d6283-1125-498e-8c9e-6a96e537cbdb

	measure 'Savings %' = ```
			
			/* % de Ahorro por Plan */
			DIVIDE (
			    [Discount Amount],
			    [Gross Amount Total],
			    0
			)
			
			```
		lineageTag: 2c7575fa-5f67-437e-b463-5c40677ec821

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Exceeded Requests' = ```
			
			CALCULATE (
			    /* Requests Excedidos*/
			    SUM ( Billing[quantity] ),
			    Billing[exceeds_quota] = TRUE ()
			)
			
			```
		formatString: 0
		lineageTag: 8c191471-c6ea-4090-8f8a-52d7c361418f

	measure 'Avg Cost per Request' = ```
			
			/* Costo Promedio por Request (real)*/
			DIVIDE (
			    [Net Amount Total],
			    [Total Requests],
			    0
			)
			
			```
		lineageTag: fc76461a-4b74-4e85-bd52-9bdb2a611b57

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Requests' = ```
			
			SUM ( Billing[quantity] )
			
			```
		formatString: 0
		lineageTag: 6cf75f29-4a1d-48f6-b0a8-a9d5b33dbd9b

	measure 'Theoretical Cost per Request' = ```
			
			/*Costo Teórico por Request*/
			DIVIDE (
			    [Gross Amount Total],
			    [Total Requests],
			    0
			)
			
			```
		lineageTag: 116ae30e-e8cb-4e75-ac0c-45eef9cdd9c3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Net Amount by Model' = ```
			
			[Net Amount Total]
			
			```
		formatString: 0
		lineageTag: d5ecc560-9a8f-4796-9e7c-050d12f69bc8

	measure 'Quota Usage %' = ```
			
			DIVIDE (
			    [Total Requests],
			    MAX (Billing[total_monthly_quota] ),
			    0
			)
			
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		lineageTag: bae6380a-9fa0-4374-a152-f51b9be22462

	measure 'Reporting Period' = ```
			
			MIN ( Dim_Date[Date] ) & " - " & MAX ( Dim_Date[Date] )
			
			```
		lineageTag: fe20a818-761a-4b7f-b51b-80df0e97ac02

	measure 'Last Refresh Date' = ```
			
			NOW ()
			
			```
		formatString: General Date
		lineageTag: b132ccfd-b8ab-4e45-87a5-747f51d83c7a

	measure 'Discount Amount' = ```
			
			/* Gross Amount Total (costo teórico) */
			SUM ( Billing[discount_amount] )
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 7babba2f-e224-4504-b1af-6fed4d8b3e30

	measure 'Avg Daily Requests' = ```
			
			AVERAGEX (
			    VALUES ( Dim_Date[Date] ),
			    [Total Requests]
			)
			
			```
		formatString: #,0.00
		lineageTag: 43214371-589b-4d7d-8acc-fb101f80f2cf

	measure 'MTD Requests' = ```
			
			TOTALMTD (
			    [Total Requests],
			    Dim_Date[Date]
			)
			
			```
		formatString: #,0
		lineageTag: b65796fe-e16a-4187-b354-4528d96a08ee

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Model Usage %' = ```
			
			DIVIDE (
			    [Total Requests],
			    CALCULATE ( [Total Requests], ALL ( Billing[model] ) ),
			    0
			)
			
			```
		lineageTag: d5ddf2aa-4915-427e-b599-e4bb7d430dd5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Requests by User' = ```
			
			[Total Requests]
			
			```
		formatString: #,0.###############\ "€";-#,0.###############\ "€";#,0.###############\ "€"
		lineageTag: 3dac165d-1e9f-4813-8941-651f21f018ea

		annotation PBI_FormatHint = {"currencyCulture":"es-ES"}

	measure 'User Contribution %' = ```
			
			DIVIDE (
			    [Total Requests],
			    CALCULATE ( [Total Requests], ALL ( Billing[username] ) ),
			    0
			)
			
			```
		lineageTag: 66ea2166-724d-469c-ad41-769f35d87ad6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Premium Requests' = ```
			
			SUM ( Billing[quantity] )
			
			```
