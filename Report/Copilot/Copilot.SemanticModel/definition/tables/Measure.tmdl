	measure Medida
		lineageTag: 07abe462-0eb9-4c46-8035-d41b23459fcd

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure 'Remaining Quota' = ```
			
			[Monthly Quota] - [Premium Requests]
			
			```
		lineageTag: e720354e-bd0a-4c56-aa02-9568c7970bc6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Daily Premium Requests' = ```
			
			AVERAGEX (
			    VALUES ( Dim_Date[Date] ),
			    [Premium Requests]
			)
			
			```
		formatString: #,0.###############\ "€";-#,0.###############\ "€";#,0.###############\ "€"
		lineageTag: 83632f5f-133a-49b4-a9fb-27dcf5a9a04e

		annotation PBI_FormatHint = {"currencyCulture":"es-ES"}

	measure 'Projected Month Requests' = ```
			
			VAR DaysInPeriod =
			    CALCULATE ( DISTINCTCOUNT ( Dim_Date[Date] ), ALLSELECTED ( Dim_Date[Date] ) )
			VAR CurrentBurn =
			    [Avg Daily Premium Requests]
			VAR DaysMonth =
			    DAY ( EOMONTH ( MAX ( Dim_Date[Date] ), 0 ) )
			RETURN
			CurrentBurn * DaysMonth
			
			```
		formatString: #,0.###############\ "€";-#,0.###############\ "€";#,0.###############\ "€"
		lineageTag: b8f0e9f6-5d18-40e5-b431-a3f87b0d3f40

		annotation PBI_FormatHint = {"currencyCulture":"es-ES"}

	measure 'Projected Over Quota' = ```
			
			MAX ( 0, [Projected Month Requests] - [Monthly Quota] )
			
			```
		lineageTag: 4ccd7df8-9279-46d7-9765-d2ce2fcd18c1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

